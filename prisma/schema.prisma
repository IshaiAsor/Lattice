// Lattice Platform — schema v2.2
// Added: blueprint_action_groups, user_action_groups, group scope on rules/emergency,
//        trace_id on PipelineRun + EmergencyEvent
// Tiers: CATALOG (admin templates) → BLUEPRINT (admin packages) → USER (independent copies)
// Generic versioned ML pipeline replaces hard-coded VLM/LLM paths.

generator client {
  provider = "prisma-client-js"
  output   = "../packages/prisma-client/src/generated"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum BlueprintStatus {
  draft
  published
}

enum StageKind {
  vlm
  sensor_digest
  llm
  command_exec
}

enum TriggerKind {
  telemetry
  schedule
  rule
}

enum RuleActionKind {
  set_state
  run_pipeline
}

enum RuleActionScope {
  instance
  capability
  group
}

// ─── Identity ────────────────────────────────────────────────────────────────

model User {
  id                  Int       @id @default(autoincrement())
  user_type           Int       @default(0)
  role                String    @default("user") @db.VarChar(50)
  user_name           String?   @unique @db.VarChar(255)
  password            String?   @db.VarChar(255)
  google_id           String?   @unique @db.VarChar(255)
  email               String    @unique @db.VarChar(255)
  full_name           String?   @db.VarChar(255)
  profile_picture_url String?
  created_at          DateTime? @default(now()) @db.Timestamptz(6)
  updated_at          DateTime? @default(now()) @db.Timestamptz(6)

  device_models   UserDeviceModel[]
  devices         UserDevice[]
  rules           Rule[]
  emergency_rules EmergencyRule[]
  pipelines       Pipeline[]
  blueprints      Blueprint[]
  derived         UserBlueprint[]
  login_audit     UserLoginAudit[]

  @@map("users")
}

model UserLoginAudit {
  id         Int       @id @default(autoincrement())
  user_id    Int
  login_at   DateTime? @default(now()) @db.Timestamptz(6)
  ip_address String?   @db.VarChar(100)
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_login_audit")
}

model MqttUser {
  id            Int       @id @default(autoincrement())
  username      String    @unique @db.VarChar(100)
  password_hash String    @db.VarChar(100)
  is_superuser  Boolean?  @default(false)
  created_at    DateTime? @default(now()) @db.Timestamp(6)

  @@map("mqtt_user")
}

// ─── Capability vocab (Google) ───────────────────────────────────────────────

model GoogleActionType {
  id            Int           @id @default(autoincrement())
  key           String        @unique @db.VarChar(255)
  name          String        @db.VarChar(255)
  created_at    DateTime?     @default(now()) @db.Timestamp(6)
  model_actions ModelAction[]

  @@map("google_action_types")
}

model GoogleTrait {
  id          Int                @id @default(autoincrement())
  key         String             @unique @db.VarChar(255)
  name        String             @db.VarChar(255)
  params      Json?
  created_at  DateTime?          @default(now()) @db.Timestamp(6)
  model_links ModelActionTrait[]

  @@map("google_traits")
}

// ─── CATALOG (admin templates) ───────────────────────────────────────────────

model DeviceModel {
  id           Int                  @id @default(autoincrement())
  model_key    String?              @db.VarChar(255)
  version      String?              @db.VarChar(255)
  display_name String               @unique @db.VarChar(255)
  created_at   DateTime?            @default(now()) @db.Timestamp(6)
  updated_at   DateTime?            @default(now()) @db.Timestamp(6)
  actions      ModelAction[]
  slots        BlueprintDeviceSlot[]

  @@map("device_models")
}

model ModelAction {
  id                    Int                @id @default(autoincrement())
  device_model_id       Int
  action_key            String             @db.VarChar(255)
  capability            String             @db.VarChar(64)
  google_action_type_id Int
  mqtt_type             String?            @db.VarChar(255)
  mqtt_name             String?            @db.VarChar(255)
  params                Json?
  pins                  Json?
  telemetry_interval_ms Int?
  device_model          DeviceModel        @relation(fields: [device_model_id], references: [id], onDelete: Cascade)
  google_action_type    GoogleActionType   @relation(fields: [google_action_type_id], references: [id], onDelete: Cascade)
  traits                ModelActionTrait[]

  @@unique([device_model_id, action_key])
  @@map("model_actions")
}

model ModelActionTrait {
  id              Int         @id @default(autoincrement())
  model_action_id Int
  google_trait_id Int
  model_action    ModelAction @relation(fields: [model_action_id], references: [id], onDelete: Cascade)
  google_trait    GoogleTrait @relation(fields: [google_trait_id], references: [id], onDelete: Cascade)

  @@unique([model_action_id, google_trait_id])
  @@map("model_action_traits")
}

// ─── ML REGISTRY (admin, global — service-routed by kind+name+version) ───────

model MlModel {
  id            Int                    @id @default(autoincrement())
  kind          String                 @db.VarChar(20)   // "vlm", "llm", etc.
  name          String                 @db.VarChar(255)
  version       String                 @db.VarChar(50)
  description   String?                @db.Text
  config        Json?
  created_at    DateTime?              @default(now()) @db.Timestamp(6)
  pipeline_stages          PipelineStage[]
  blueprint_pipeline_stages BlueprintPipelineStage[]

  @@unique([kind, name, version])
  @@map("ml_models")
}

// ─── BLUEPRINT (admin packages, versioned) ───────────────────────────────────

model Blueprint {
  id           Int             @id @default(autoincrement())
  name         String          @db.VarChar(255)
  description  String?         @db.Text
  category     String?         @db.VarChar(100)
  created_by   Int
  status       BlueprintStatus @default(draft)
  version      Int             @default(1)
  created_at   DateTime?       @default(now()) @db.Timestamp(6)
  updated_at   DateTime?       @default(now()) @db.Timestamp(6)
  creator         User                     @relation(fields: [created_by], references: [id], onDelete: Cascade)
  slots           BlueprintDeviceSlot[]
  rules           BlueprintRule[]
  emergency_rules BlueprintEmergencyRule[]
  pipelines       BlueprintPipeline[]
  action_groups   BlueprintActionGroup[]
  derived         UserBlueprint[]

  @@map("blueprints")
}

model BlueprintDeviceSlot {
  id              Int         @id @default(autoincrement())
  blueprint_id    Int
  device_model_id Int
  role            String      @db.VarChar(255)
  min_count       Int         @default(1)
  max_count       Int?
  sort_order      Int         @default(0)
  blueprint     Blueprint              @relation(fields: [blueprint_id], references: [id], onDelete: Cascade)
  device_model  DeviceModel            @relation(fields: [device_model_id], references: [id], onDelete: Restrict)
  action_groups BlueprintActionGroup[]

  @@map("blueprint_device_slots")
}

model BlueprintRule {
  id           Int       @id @default(autoincrement())
  blueprint_id Int
  name         String    @db.VarChar(255)
  match        String    @default("AND") @db.VarChar(3)
  cooldown_sec Int       @default(60)
  enabled      Boolean   @default(true)
  blueprint    Blueprint @relation(fields: [blueprint_id], references: [id], onDelete: Cascade)
  conditions   BlueprintRuleCondition[]
  actions      BlueprintRuleAction[]

  @@map("blueprint_rules")
}

model BlueprintRuleCondition {
  id                Int           @id @default(autoincrement())
  blueprint_rule_id Int
  kind              String        @db.VarChar(30)
  params            Json
  rule              BlueprintRule @relation(fields: [blueprint_rule_id], references: [id], onDelete: Cascade)

  @@map("blueprint_rule_conditions")
}

model BlueprintRuleAction {
  id                       Int            @id @default(autoincrement())
  blueprint_rule_id        Int
  kind                     RuleActionKind @default(set_state)
  capability               String?        @db.VarChar(64)
  target_state             String?        @db.VarChar(255)
  blueprint_pipeline_id    Int?
  delay_sec                Int            @default(0)
  rule                     BlueprintRule     @relation(fields: [blueprint_rule_id], references: [id], onDelete: Cascade)
  blueprint_pipeline       BlueprintPipeline? @relation(fields: [blueprint_pipeline_id], references: [id], onDelete: SetNull)

  @@map("blueprint_rule_actions")
}

model BlueprintEmergencyRule {
  id                Int       @id @default(autoincrement())
  blueprint_id      Int
  name              String    @db.VarChar(255)
  source_capability String    @db.VarChar(64)
  operator          String    @db.VarChar(5)
  threshold         String    @db.VarChar(100)
  target_capability String?   @db.VarChar(64)
  target_state      String?   @db.VarChar(255)
  enabled           Boolean   @default(true)
  blueprint         Blueprint @relation(fields: [blueprint_id], references: [id], onDelete: Cascade)

  @@map("blueprint_emergency_rules")
}

// Blueprint pipeline: ordered stages cloned into user pipelines on derive

model BlueprintPipeline {
  id               Int         @id @default(autoincrement())
  blueprint_id     Int
  name             String      @db.VarChar(255)
  enabled          Boolean     @default(true)
  trigger_kind     TriggerKind @default(telemetry)
  trigger_capability String?   @db.VarChar(64)
  trigger_config   Json?
  blueprint        Blueprint   @relation(fields: [blueprint_id], references: [id], onDelete: Cascade)
  stages           BlueprintPipelineStage[]
  rule_actions     BlueprintRuleAction[]

  @@map("blueprint_pipelines")
}

model BlueprintPipelineStage {
  id                   Int               @id @default(autoincrement())
  blueprint_pipeline_id Int
  position             Int
  stage_kind           StageKind
  ml_model_id          Int?
  component_version    String?           @db.VarChar(50)
  config               Json?
  pipeline             BlueprintPipeline @relation(fields: [blueprint_pipeline_id], references: [id], onDelete: Cascade)
  ml_model             MlModel?          @relation(fields: [ml_model_id], references: [id], onDelete: Restrict)

  @@map("blueprint_pipeline_stages")
}

// ─── USER-OWNED definitions (independent snapshot) ───────────────────────────

model UserDeviceModel {
  id                  Int       @id @default(autoincrement())
  user_id             Int
  source_blueprint_id Int?
  source_model_id     Int?
  model_key           String?   @db.VarChar(255)
  version             String?   @db.VarChar(255)
  display_name        String    @db.VarChar(255)
  created_at          DateTime? @default(now()) @db.Timestamp(6)
  updated_at          DateTime? @default(now()) @db.Timestamp(6)
  user        User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  action_defs UserActionDef[]
  devices     UserDevice[]

  @@map("user_device_models")
}

model UserActionDef {
  id                    Int             @id @default(autoincrement())
  user_device_model_id  Int
  source_action_id      Int?
  action_key            String          @db.VarChar(255)
  capability            String          @db.VarChar(64)
  google_action_type_id Int
  mqtt_type             String?         @db.VarChar(255)
  mqtt_name             String?         @db.VarChar(255)
  params                Json?
  pins                  Json?
  telemetry_interval_ms Int?
  device_model UserDeviceModel     @relation(fields: [user_device_model_id], references: [id], onDelete: Cascade)
  traits       UserActionDefTrait[]
  actions      UserAction[]

  @@unique([user_device_model_id, action_key])
  @@map("user_action_defs")
}

model UserActionDefTrait {
  id                 Int           @id @default(autoincrement())
  user_action_def_id Int
  google_trait_id    Int
  action_def         UserActionDef @relation(fields: [user_action_def_id], references: [id], onDelete: Cascade)

  @@unique([user_action_def_id, google_trait_id])
  @@map("user_action_def_traits")
}

// ─── USER instances ──────────────────────────────────────────────────────────

model UserDevice {
  id                   Int             @id @default(autoincrement())
  user_id              Int
  user_device_model_id Int
  source_blueprint_id  Int?
  mac_id               String?         @unique @db.VarChar(255)
  name                 String          @db.VarChar(255)
  online               Boolean?        @default(false)
  last_seen_at         DateTime?       @default(now()) @db.Timestamp(6)
  created_at           DateTime?       @default(now()) @db.Timestamp(6)
  updated_at           DateTime?       @default(now()) @db.Timestamp(6)
  user         User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  device_model UserDeviceModel @relation(fields: [user_device_model_id], references: [id], onDelete: Cascade)
  actions      UserAction[]
  action_groups UserActionGroup[]

  @@map("user_devices")
}

model UserAction {
  id                  Int            @id @default(autoincrement())
  user_device_id      Int
  user_action_def_id  Int
  user_action_group_id Int?
  name                String         @db.VarChar(255)
  state               String?        @db.Text
  sort_order          Int            @default(0)
  created_at          DateTime?      @default(now()) @db.Timestamp(6)
  updated_at          DateTime?      @default(now()) @db.Timestamp(6)
  user_device   UserDevice     @relation(fields: [user_device_id], references: [id], onDelete: Cascade)
  action_def    UserActionDef  @relation(fields: [user_action_def_id], references: [id], onDelete: Cascade)
  action_group  UserActionGroup? @relation(fields: [user_action_group_id], references: [id], onDelete: SetNull)
  rule_targets       RuleAction[]
  emergency_source   EmergencyRule[] @relation("EmSource")
  emergency_target   EmergencyRule[] @relation("EmTarget")
  pipeline_triggers  PipelineRun[]
  readings           SensorReading[]

  @@map("user_actions")
}

// ─── USER automation ─────────────────────────────────────────────────────────

model Rule {
  id                  Int             @id @default(autoincrement())
  user_id             Int
  source_blueprint_id Int?
  name                String          @db.VarChar(255)
  match               String          @default("AND") @db.VarChar(3)
  cooldown_sec        Int             @default(60)
  enabled             Boolean         @default(true)
  last_fired_at       DateTime?       @db.Timestamp(6)
  created_at          DateTime?       @default(now()) @db.Timestamp(6)
  updated_at          DateTime?       @default(now()) @db.Timestamp(6)
  user       User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  conditions RuleCondition[]
  actions    RuleAction[]

  @@map("rules")
}

model RuleCondition {
  id      Int    @id @default(autoincrement())
  rule_id Int
  // kind: schedule | device_status | threshold | vlm_result | vlm_decision | pipeline_result
  kind    String @db.VarChar(30)
  params  Json
  rule    Rule   @relation(fields: [rule_id], references: [id], onDelete: Cascade)

  @@map("rule_conditions")
}

model RuleAction {
  id             Int             @id @default(autoincrement())
  rule_id        Int
  kind           RuleActionKind  @default(set_state)
  scope          RuleActionScope @default(instance)
  user_action_id Int?
  capability     String?         @db.VarChar(64)
  group_id       Int?
  target_state   String?         @db.VarChar(255)
  pipeline_id    Int?
  delay_sec      Int             @default(0)
  rule        Rule             @relation(fields: [rule_id], references: [id], onDelete: Cascade)
  user_action UserAction?      @relation(fields: [user_action_id], references: [id], onDelete: Cascade)
  action_group UserActionGroup? @relation(fields: [group_id], references: [id], onDelete: SetNull)
  pipeline    Pipeline?        @relation(fields: [pipeline_id], references: [id], onDelete: SetNull)

  @@map("rule_actions")
}

model EmergencyRule {
  id                      Int        @id @default(autoincrement())
  user_id                 Int
  source_blueprint_id     Int?
  name                    String     @db.VarChar(255)
  source_scope            RuleActionScope @default(instance)
  source_user_action_id   Int?
  source_capability       String?         @db.VarChar(64)
  source_group_id         Int?
  operator                String          @db.VarChar(5)
  threshold               String          @db.VarChar(100)
  target_scope            RuleActionScope @default(instance)
  target_user_action_id   Int?
  target_capability       String?         @db.VarChar(64)
  target_group_id         Int?
  target_state            String?         @db.VarChar(255)
  enabled                 Boolean         @default(true)
  created_at              DateTime?       @default(now()) @db.Timestamp(6)
  user           User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  source_action  UserAction?      @relation("EmSource", fields: [source_user_action_id], references: [id], onDelete: Cascade)
  target_action  UserAction?      @relation("EmTarget", fields: [target_user_action_id], references: [id], onDelete: SetNull)
  source_group   UserActionGroup? @relation("EmSourceGroup", fields: [source_group_id], references: [id], onDelete: SetNull)
  target_group   UserActionGroup? @relation("EmTargetGroup", fields: [target_group_id], references: [id], onDelete: SetNull)
  events         EmergencyEvent[]

  @@map("emergency_rules")
}

model EmergencyEvent {
  id                Int           @id @default(autoincrement())
  emergency_rule_id Int
  value             String        @db.VarChar(255)
  trace_id          String?       @db.VarChar(36)
  fired_at          DateTime      @default(now()) @db.Timestamp(6)
  rule              EmergencyRule @relation(fields: [emergency_rule_id], references: [id], onDelete: Cascade)

  @@map("emergency_events")
}

// ─── USER pipelines (generic versioned processing chains) ────────────────────

model Pipeline {
  id                 Int         @id @default(autoincrement())
  user_id            Int
  source_blueprint_id Int?
  name               String      @db.VarChar(255)
  enabled            Boolean     @default(true)
  trigger_kind       TriggerKind @default(telemetry)
  trigger_capability String?     @db.VarChar(64)
  trigger_config     Json?
  created_at         DateTime?   @default(now()) @db.Timestamp(6)
  user         User            @relation(fields: [user_id], references: [id], onDelete: Cascade)
  stages       PipelineStage[]
  runs         PipelineRun[]
  rule_actions RuleAction[]

  @@map("pipelines")
}

model PipelineStage {
  id                Int       @id @default(autoincrement())
  pipeline_id       Int
  position          Int
  stage_kind        StageKind
  ml_model_id       Int?
  component_version String?   @db.VarChar(50)
  config            Json?
  pipeline Pipeline @relation(fields: [pipeline_id], references: [id], onDelete: Cascade)
  ml_model MlModel? @relation(fields: [ml_model_id], references: [id], onDelete: Restrict)

  @@map("pipeline_stages")
}

model PipelineRun {
  id                      Int       @id @default(autoincrement())
  pipeline_id             Int
  trigger_user_action_id  Int?
  trace_id                String?   @db.VarChar(36)
  status                  String    @db.VarChar(20)
  input                   Json?
  output                  Json?
  started_at              DateTime  @default(now()) @db.Timestamp(6)
  finished_at             DateTime? @db.Timestamp(6)
  pipeline       Pipeline    @relation(fields: [pipeline_id], references: [id], onDelete: Cascade)
  trigger_action UserAction? @relation(fields: [trigger_user_action_id], references: [id], onDelete: SetNull)
  stage_runs     PipelineRunStage[]

  @@map("pipeline_runs")
}

model PipelineRunStage {
  id              Int         @id @default(autoincrement())
  pipeline_run_id Int
  position        Int
  stage_kind      StageKind
  component       String?     @db.VarChar(255)
  version         String?     @db.VarChar(50)
  input           Json?
  output          Json?
  duration_ms     Int?
  created_at      DateTime    @default(now()) @db.Timestamp(6)
  pipeline_run PipelineRun @relation(fields: [pipeline_run_id], references: [id], onDelete: Cascade)

  @@map("pipeline_run_stages")
}

// ─── History & derivation ────────────────────────────────────────────────────

model SensorReading {
  id             Int        @id @default(autoincrement())
  user_action_id Int
  value          String     @db.VarChar(255)
  recorded_at    DateTime   @default(now()) @db.Timestamp(6)
  user_action    UserAction @relation(fields: [user_action_id], references: [id], onDelete: Cascade)

  @@index([user_action_id, recorded_at])
  @@map("sensor_readings")
}

model UserBlueprint {
  id           Int       @id @default(autoincrement())
  user_id      Int
  blueprint_id Int
  version      Int
  derived_at   DateTime  @default(now()) @db.Timestamp(6)
  user      User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  blueprint Blueprint @relation(fields: [blueprint_id], references: [id], onDelete: Cascade)

  @@unique([user_id, blueprint_id])
  @@map("user_blueprints")
}

// ─── Action grouping ─────────────────────────────────────────────────────────

model UserActionGroup {
  id                  Int       @id @default(autoincrement())
  user_device_id      Int
  user_id             Int
  source_blueprint_id Int?
  name                String    @db.VarChar(255)
  description         String?   @db.Text
  icon                String?   @db.VarChar(50)
  color               String?   @db.VarChar(20)
  sort_order          Int       @default(0)
  user_device  UserDevice @relation(fields: [user_device_id], references: [id], onDelete: Cascade)
  actions      UserAction[]
  rule_actions RuleAction[]
  em_source    EmergencyRule[] @relation("EmSourceGroup")
  em_target    EmergencyRule[] @relation("EmTargetGroup")

  @@map("user_action_groups")
}

model BlueprintActionGroup {
  id                     Int                 @id @default(autoincrement())
  blueprint_id           Int
  blueprint_device_slot_id Int
  name                   String              @db.VarChar(255)
  description            String?             @db.Text
  icon                   String?             @db.VarChar(50)
  color                  String?             @db.VarChar(20)
  sort_order             Int                 @default(0)
  blueprint     Blueprint           @relation(fields: [blueprint_id], references: [id], onDelete: Cascade)
  device_slot   BlueprintDeviceSlot @relation(fields: [blueprint_device_slot_id], references: [id], onDelete: Cascade)

  @@map("blueprint_action_groups")
}
