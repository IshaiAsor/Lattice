{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-backend",
      "type": "shell",
      "command": "npx tsc -p tsconfig.json",
      "options": {
        "cwd": "${workspaceFolder:Backend API}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always"
      },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "kill-old-tunnel",
      "type": "shell",
      "command": "npx -y kill-port 5432",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "kill-port-3000",
      "type": "shell",
      "command": "npx -y kill-port 3000",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "kill-port-3002",
      "type": "shell",
      "command": "npx -y kill-port 3002",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "kill-port-3003",
      "type": "shell",
      "command": "npx -y kill-port 3003",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "kill-port-3004",
      "type": "shell",
      "command": "npx -y kill-port 3004",
      "presentation": { "reveal": "silent" }
    },
    {
      "label": "ssh-postgres-tunnel",
      "dependsOn": ["kill-old-tunnel"],
      "dependsOrder": "sequence",
      "type": "shell",
      "command": "ssh -L 5432:localhost:5432 -i C:\\Users\\Consist\\Desktop\\k3s-infra\\k3s-a1.1.key ubuntu@k3sa1-ishai.duckdns.org 'sudo fuser -k 5432/tcp || true; sudo kubectl port-forward svc/postgres 5432:5432 -n my-apps'",
      "isBackground": true,
      "problemMatcher": {
        "pattern": [
          {
            "regexp": ".",
            "file": 1,
            "location": 2,
            "message": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "^Forwarding from"
        }
      }
    },
    {
      "label": "pre-debug-compiled",
      "dependsOn": ["build-backend"],
      "dependsOrder": "sequence"
    },
    {
      "label": "serve-backoffice",
      "type": "shell",
      "command": "npm start",
      "options": {
        "cwd": "${workspaceFolder:Backoffice UI}"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "Generating browser application bundles|Compiling..."
          },
          "endsPattern": {
            "regexp": "Application bundle generation complete|Compiled successfully"
          }
        }
      }
    },
    {
      "label": "open-cluster-tunnels",
      "type": "shell",
      "command": "powershell -ExecutionPolicy Bypass -File C:\\Projects\\open_cluster_tunnels.ps1",
      "isBackground": true,
      "presentation": {
        "reveal": "always"
      },
      "problemMatcher": {
        "pattern": [
          {
            "regexp": ".",
            "file": 1,
            "location": 2,
            "message": 3
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "."
        }
      }
    },
    {
      "label": "build-device-gateway",
      "type": "shell",
      "command": "npx tsc -p tsconfig.json",
      "options": { "cwd": "${workspaceFolder:Device Gateway}" },
      "group": "build",
      "presentation": { "reveal": "always" },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "build-google-home",
      "type": "shell",
      "command": "npx tsc -p tsconfig.json",
      "options": { "cwd": "${workspaceFolder:Google Home}" },
      "group": "build",
      "presentation": { "reveal": "always" },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "build-ml-router",
      "type": "shell",
      "command": "npx tsc -p tsconfig.json",
      "options": { "cwd": "${workspaceFolder:ML Router}" },
      "group": "build",
      "presentation": { "reveal": "always" },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "build-workers",
      "type": "shell",
      "command": "npx tsc -p tsconfig.json",
      "options": { "cwd": "${workspaceFolder:Workers}" },
      "group": "build",
      "presentation": { "reveal": "always" },
      "problemMatcher": ["$tsc"]
    },
    {
      "type": "PlatformIO",
      "task": "Build",
      "problemMatcher": [
        "$platformio"
      ],
      "options": {
        "cwd": "${workspaceFolder:ESP32 Firmware}"
      },
      "label": "PlatformIO: Build (ESP32Code)"
    }
  ]
}
